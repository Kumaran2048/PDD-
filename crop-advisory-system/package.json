{
    "name": "crop-advisory-system",
    "version": "1.0.0",
    "description": "AI-Based Crop Advisory & Farm Management System",
    "scripts": {
        "install:all": "npm install --prefix crop-frontend && npm install --prefix crop-advisory-backend/crop-advisory/server",
        "dev:frontend": "npm run dev --prefix crop-frontend",
        "dev:backend": "npm run dev --prefix crop-advisory-backend/crop-advisory/server",
        "dev:ml": "cd crop-advisory-backend/crop-advisory/ml-service && python app.py",
        "build": "npm install && npm run install:all",
        "start": "concurrently \"npm start --prefix crop-advisory-backend/crop-advisory/server\" \"npm run dev --prefix crop-frontend -- --host 0.0.0.0\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}