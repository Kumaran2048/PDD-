# ══════════════════════════════════════════════════
#   CROP ADVISORY SYSTEM - Environment Variables
#   Copy this file → rename it to .env → fill values
# ══════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────
PORT=5000

# ── MongoDB ─────────────────────────────────────────
# Option A: Local MongoDB (default, no account needed)
MONGO_URI=mongodb://127.0.0.1:27017/cropAdvisory

# Option B: MongoDB Atlas (cloud) — free at mongodb.com/atlas
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cropAdvisory?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────
# Any long random string — change this in production!
JWT_SECRET=cropAdvisorySecretKey2024
JWT_EXPIRE=7d

# ── OpenWeather API ─────────────────────────────────
# REQUIRED for Weather page
# 1. Sign up free at: https://openweathermap.org/api
# 2. Go to API Keys → copy your default key
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Python Flask ML Service ─────────────────────────
# URL where the Python Flask ml-service runs (don't change unless different port)
FLASK_URL=http://localhost:8000

# ── Data.gov.in (Agmarknet Market Prices) ───────────
# REQUIRED for Market Prices page
# 1. Register free at: https://data.gov.in/user/register
# 2. Go to My Account → API Keys → Generate key
AGMARKNET_API_KEY=your_agmarknet_api_key_here
